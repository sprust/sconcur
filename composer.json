{
    "name": "sconcur/sconcur",
    "description": "PHP concurrency library backed by an extension written in Go",
    "license": "MIT",
    "version": "0.0.1",
    "authors": [
        {
            "name": "Pavel",
            "email": "sprust28@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-msgpack": "*",
        "ext-mongodb": "^1.21",
        "psr/http-client": "^1.0",
        "psr/http-message": "^2.0",
        "psr/http-factory": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.1",
        "symfony/var-dumper": "^7.3",
        "vlucas/phpdotenv": "^5.6",
        "mongodb/mongodb": "^1.21",
        "friendsofphp/php-cs-fixer": "^3.91",
        "nyholm/psr7": "^1.8"
    },
    "suggest": {
        "ext-pcntl": "Required for graceful shutdown of the HTTP server (SIGTERM/SIGINT handling); the server otherwise runs until the process is killed"
    },
    "bin": [
        "bin/sconcur-server"
    ],
    "autoload": {
        "psr-4": {
            "SConcur\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SConcur\\Tests\\Feature\\": "tests/feature",
            "SConcur\\Tests\\Impl\\": "tests/impl"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
