# Docker user and group IDs (root user is set by default)
# To find your user ID and group ID on Linux, use commands: `id -u` and `id -g`
DOCKER_USER_ID=0
DOCKER_GROUP_ID=0

# http server (port published to the host)
HTTP_SERVER_PORT=8080
HTTP_SERVER_DOCKER_PORT=28080

# mongodb
MONGO_HOST=sc-mongodb
MONGO_ADMIN_USERNAME=sc_admin
MONGO_ADMIN_PASSWORD=_sc_password_567
MONGO_PORT=27017
MONGO_DOCKER_PORT=29079

# mysql
MYSQL_HOST=sc-mysql
MYSQL_PORT=3306
MYSQL_DATABASE=u_test
MYSQL_USER=sc_user
MYSQL_PASSWORD=_sc_password_567
MYSQL_ROOT_PASSWORD=_sc_root_password_567
MYSQL_DOCKER_PORT=23306

# postgres
POSTGRES_HOST=sc-postgres
POSTGRES_PORT=5432
POSTGRES_DB=u_test
POSTGRES_USER=sc_user
POSTGRES_PASSWORD=_sc_password_567
POSTGRES_DOCKER_PORT=25432
