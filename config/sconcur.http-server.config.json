{
    "workerScript": "/sconcur/tests/servers/http/http-server.php",
    "workerCount": 3,
    "phpBinary": "php",
    "phpArgs": ["-d", "extension=/sconcur/ext/build/sconcur.so"],
    "workerArgs": [],
    "env": {
        "SCONCUR_ADMIN_TOKEN": "23c30b4089383dd332585af6f02ff65de38179d52546b770942bd63e9894c3ec",
        "SCONCUR_STATS_PORT": "8081"
    },
    "runtimeDir": "/sconcur/tests/storage/servers",
    "logDir": "/sconcur/tests/storage/logs",
    "name": "sconcur-http-server",
    "rotateDays": 3,
    "logTo": "both",
    "restartPolicy": "always",
    "shutdownTimeoutMs": 10000,
    "restartBackoffMs": 200,
    "maxRestartBackoffMs": 30000,
    "server": {
        "address": "0.0.0.0:8080",
        "reusePort": true,
        "maxRequests": 0,
        "maxConcurrency": 0,
        "maxRequestBody": 10485760,
        "readHeaderTimeoutMs": 10000,
        "readTimeoutMs": 30000,
        "writeTimeoutMs": 30000,
        "idleTimeoutMs": 60000,
        "handlerTimeoutMs": 60000,
        "shutdownTimeoutMs": 5000
    }
}
