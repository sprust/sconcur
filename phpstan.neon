parameters:
    paths:
        - ./src
        - ./tests/feature
    level: 6

    ignoreErrors:
        -
            messages:
                - '#unction SConcur\\Extension\\(cancelTask|destroy|push|next|stopFlow|httpStopAccepting|socketStopAccepting|wsStopAccepting|tasksCount|wait|waitAny|waitAnyTimeout|version) not found#'
                - '#generic class Fiber [\s\S]* not specify its types: TStart, TResume, TReturn, TSuspend#'
